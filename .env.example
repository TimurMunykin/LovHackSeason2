# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI API (for AI browser agent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_SCHEDULE_EXTRACTOR=gpt-5.4-nano

# Skip Google OAuth for local development (set to false in production!)
DEV_AUTH_BYPASS=false

# Session encryption key
SESSION_SECRET=change-me-to-random-string

# Database
POSTGRES_PASSWORD=change-me

# Docker Hub (for build-release.sh and deploy.sh)
DOCKER_REPO_PREFIX=yourdockerhubuser

# Production only
APP_DOMAIN=your-domain.com
IMAGE_TAG=latest
