# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key-here

# AI model names (optional — defaults to gpt-4o-mini)
OPENAI_MODEL_NAVIGATOR=gpt-4o-mini
OPENAI_MODEL_EXTRACTOR=gpt-4o-mini

# Database
DB_PASSWORD=changeme

# CORS — origin of the frontend that will call this backend
ALLOWED_ORIGIN=http://localhost:3000

# VNC viewer URL returned to the frontend for embedding
VNC_URL=http://localhost:6080/vnc_lite.html?autoconnect=true&resize=scale&reconnect=true&reconnect_delay=1000
